@page "/upload"
@rendermode InteractiveServer
@using SmartDocumentProcessing.Data
@using SmartDocumentProcessing.Models
@using SmartDocumentProcessing.Services
@inject AppDbContext DbContext
@inject DocumentExtractionService ExtractionService
@inject ValidationService ValidationService

<h3>Upload Document</h3>

<div class="card p-4">
    <InputFile OnChange="HandleFileUpload" />

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-success mt-3">
            @message
        </div>
    }
</div>

@code {
    private string message = "";

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file == null)
            return;

        // 1. Spremi fajl na disk
        Directory.CreateDirectory("wwwroot/uploads");

        var uniqueFileName = $"{Guid.NewGuid()}_{file.Name}";
        var filePath = Path.Combine("wwwroot/uploads", uniqueFileName);

        using (var stream = File.Create(filePath))
        {
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
        }

        // 2. Pročitaj sadržaj ako je TXT
        string fileContent = "";
        var extension = Path.GetExtension(file.Name).ToLower();

        using (var reader = new StreamReader(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024)))
        {
            fileContent = await reader.ReadToEndAsync();
        }

        Document document;

        if (extension == ".txt")
        {
            document = ExtractionService.ExtractFromText(fileContent);
        }
        else if (extension == ".csv")
        {
            document = ExtractionService.ExtractFromCsv(fileContent);
        }
        else
        {
            document = new Document
            {
                Status = "Needs Review"
            };
        }

        // 4. Dodatni podaci
        document.OriginalFileName = file.Name;
        document.Status = "Needs Review";
        document.CreatedAt = DateTime.Now;

        // 5. Spremanje u bazu
        DbContext.Documents.Add(document);
        await DbContext.SaveChangesAsync();
        
        var issues = await ValidationService.ValidateDocumentAsync(document);

        if (issues.Any())
        {
            document.Status = "Needs Review";
            DbContext.ValidationIssues.AddRange(issues);
        }
        else
        {
            document.Status = "Validated";
        }

        await DbContext.SaveChangesAsync();
        message = $"File '{file.Name}' processed and saved!";
    }
}