@page "/dashboard"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using SmartDocumentProcessing.Data
@using SmartDocumentProcessing.Models
@inject AppDbContext DbContext

<h1 class="page-title">Documents Dashboard</h1>
<p class="page-subtitle">Review processed documents, statuses and validation issues.</p>

@if (documents == null)
{
    <p>Loading...</p>
}
else if (!documents.Any())
{
    <div class="alert alert-info">No documents processed yet.</div>
}
else
{
    <table style="
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
            background:#111827;
            border-radius:12px;
            overflow:hidden;
        ">
        <thead style="background:#020617;">
            <tr>
                <th style="padding:14px; text-align:left; color:#93c5fd;">Type</th>
                <th style="padding:14px; text-align:left; color:#93c5fd;">Supplier</th>
                <th style="padding:14px; text-align:left; color:#93c5fd;">Number</th>
                <th style="padding:14px; text-align:left; color:#93c5fd;">Total</th>
                <th style="padding:14px; text-align:left; color:#93c5fd;">Status</th>
                <th style="padding:14px; text-align:left; color:#93c5fd;">Issues</th>
                <th style="padding:14px; text-align:left; color:#93c5fd;">Uploaded</th>
                <th style="padding:14px; text-align:left; color:#93c5fd;">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in documents)
            {
                var docIssues = issues.Where(i => i.DocumentId == doc.Id).ToList();

                <tr style="transition:0.2s;"
                    onmouseover="this.style.background='#1e293b'"
                    onmouseout="this.style.background='transparent'">

                    <td style="padding:14px; border-top:1px solid #1f2937;">@doc.DocumentType</td>
                    <td style="padding:14px; border-top:1px solid #1f2937;">@doc.SupplierName</td>
                    <td style="padding:14px; border-top:1px solid #1f2937;">@doc.DocumentNumber</td>
                    <td style="padding:14px; border-top:1px solid #1f2937;">@doc.Total @doc.Currency</td>

                    <td style="padding:14px; border-top:1px solid #1f2937;">
                        <span style="@GetStatusStyle(doc.Status)">
                            @doc.Status
                        </span>
                    </td>

                    <td style="padding:14px; border-top:1px solid #1f2937;">
                        @if (docIssues.Any())
                        {
                            <span style="
                                            background:#dc2626;
                                            color:white;
                                            padding:4px 8px;
                                            border-radius:6px;
                                            font-size:12px;
                                        ">
                                @docIssues.Count issue(s)
                            </span>

                            <ul style="margin-top:8px; padding-left:16px;">
                                @foreach (var issue in docIssues)
                                {
                                    <li style="color:#fca5a5;">
                                        <strong>@issue.Field:</strong> @issue.Message
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <span style="
                                            background:#16a34a;
                                            color:white;
                                            padding:4px 8px;
                                            border-radius:6px;
                                            font-size:12px;
                                        ">
                                No issues
                            </span>
                        }
                    </td>

                    <td style="padding:14px; border-top:1px solid #1f2937;">
                        @doc.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    </td>

                    <td style="padding:14px; border-top:1px solid #1f2937;">
                        <a href="/review/@doc.Id"
                           style="
                                       padding:6px 12px;
                                       background:#2563eb;
                                       color:white;
                                       border-radius:6px;
                                       text-decoration:none;
                                       font-size:13px;
                                   ">
                            Review
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Document>? documents;
    private List<ValidationIssue> issues = new();

    protected override async Task OnInitializedAsync()
    {
        documents = await DbContext.Documents
            .OrderByDescending(d => d.CreatedAt)
            .ToListAsync();

        issues = await DbContext.ValidationIssues
            .ToListAsync();
    }

    private string GetStatusStyle(string status)
    {
        return status switch
        {
            "Uploaded" => "background:#475569; color:white; padding:4px 8px; border-radius:6px; font-size:12px;",
            "Needs Review" => "background:#f59e0b; color:black; padding:4px 8px; border-radius:6px; font-size:12px;",
            "Validated" => "background:#16a34a; color:white; padding:4px 8px; border-radius:6px; font-size:12px;",
            "Rejected" => "background:#dc2626; color:white; padding:4px 8px; border-radius:6px; font-size:12px;",
            _ => "background:#334155; color:white; padding:4px 8px; border-radius:6px; font-size:12px;"
        };
    }
}