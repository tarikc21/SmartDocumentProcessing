@page "/dashboard"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using SmartDocumentProcessing.Data
@using SmartDocumentProcessing.Models
@inject AppDbContext DbContext

<h3>Documents Dashboard</h3>

@if (documents == null)
{
    <p>Loading...</p>
}
else if (!documents.Any())
{
    <div class="alert alert-info">No documents processed yet.</div>
}
else
{
    <table class="table table-striped table-hover mt-3">
        <thead>
            <tr>
                <th>Type</th>
                <th>Supplier</th>
                <th>Number</th>
                <th>Total</th>
                <th>Status</th>
                <th>Issues</th>
                <th>Uploaded</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in documents)
            {
                var docIssues = issues.Where(i => i.DocumentId == doc.Id).ToList();

                <tr>
                    <td>@doc.DocumentType</td>
                    <td>@doc.SupplierName</td>
                    <td>@doc.DocumentNumber</td>
                    <td>@doc.Total @doc.Currency</td>
                    <td>
                        <span class="@GetStatusClass(doc.Status)">
                            @doc.Status
                        </span>
                    </td>
                    <td>
                        @if (docIssues.Any())
                        {
                            <span class="badge bg-danger">@docIssues.Count issue(s)</span>

                            <ul class="mt-2 mb-0">
                                @foreach (var issue in docIssues)
                                {
                                    <li>
                                        <strong>@issue.Field:</strong> @issue.Message
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <span class="badge bg-success">No issues</span>
                        }
                    </td>
                    <td>@doc.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a class="btn btn-sm btn-primary" href="/review/@doc.Id">Review</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Document>? documents;
    private List<ValidationIssue> issues = new();

    protected override async Task OnInitializedAsync()
    {
        documents = await DbContext.Documents
            .OrderByDescending(d => d.CreatedAt)
            .ToListAsync();

        issues = await DbContext.ValidationIssues
            .ToListAsync();
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Uploaded" => "badge bg-secondary",
            "Needs Review" => "badge bg-warning text-dark",
            "Validated" => "badge bg-success",
            "Rejected" => "badge bg-danger",
            _ => "badge bg-light text-dark"
        };
    }
}