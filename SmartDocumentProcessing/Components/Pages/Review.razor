@page "/review/{Id:int}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using SmartDocumentProcessing.Data
@using SmartDocumentProcessing.Models
@using SmartDocumentProcessing.Services
@inject AppDbContext DbContext
@inject ValidationService ValidationService
@inject NavigationManager Navigation

<h3>Review Document</h3>

@if (document == null)
{
    <div class="alert alert-warning">Document not found.</div>
}
else
{
    <div class="card p-4">
        <div class="mb-3">
            <label class="form-label">Document Type</label>
            <input class="form-control" @bind="document.DocumentType" />
        </div>

        <div class="mb-3">
            <label class="form-label">Supplier Name</label>
            <input class="form-control" @bind="document.SupplierName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Document Number</label>
            <input class="form-control" @bind="document.DocumentNumber" />
        </div>

        <div class="mb-3">
            <label class="form-label">Currency</label>
            <input class="form-control" @bind="document.Currency" />
        </div>

        <div class="mb-3">
            <label class="form-label">Subtotal</label>
            <input class="form-control" type="number" step="0.01" @bind="document.Subtotal" />
        </div>

        <div class="mb-3">
            <label class="form-label">Tax</label>
            <input class="form-control" type="number" step="0.01" @bind="document.Tax" />
        </div>

        <div class="mb-3">
            <label class="form-label">Total</label>
            <input class="form-control" type="number" step="0.01" @bind="document.Total" />
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <select class="form-select" @bind="document.Status">
                <option>Uploaded</option>
                <option>Needs Review</option>
                <option>Validated</option>
                <option>Rejected</option>
            </select>
        </div>

        <button class="btn btn-success me-2" @onclick="SaveChanges">
            Save Corrections
        </button>

        <button class="btn btn-danger" @onclick="RejectDocument">
            Reject
        </button>
    </div>

    @if (issues.Any())
    {
        <div class="alert alert-danger mt-3">
            <h5>Validation Issues</h5>
            <ul>
                @foreach (var issue in issues)
                {
                    <li><strong>@issue.Field:</strong> @issue.Message</li>
                }
            </ul>
        </div>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Document? document;
    private List<ValidationIssue> issues = new();

    protected override async Task OnInitializedAsync()
    {
        document = await DbContext.Documents.FirstOrDefaultAsync(d => d.Id == Id);

        issues = await DbContext.ValidationIssues
            .Where(i => i.DocumentId == Id)
            .ToListAsync();
    }

    private async Task SaveChanges()
    {
        if (document == null)
            return;

        var oldIssues = await DbContext.ValidationIssues
            .Where(i => i.DocumentId == document.Id)
            .ToListAsync();

        DbContext.ValidationIssues.RemoveRange(oldIssues);

        var newIssues = await ValidationService.ValidateDocumentAsync(document);

        if (newIssues.Any())
        {
            document.Status = "Needs Review";
            DbContext.ValidationIssues.AddRange(newIssues);
        }
        else
        {
            document.Status = "Validated";
        }

        await DbContext.SaveChangesAsync();

        Navigation.NavigateTo("/dashboard");
    }

    private async Task RejectDocument()
{
    if (document == null)
        return;

    var oldIssues = await DbContext.ValidationIssues
        .Where(i => i.DocumentId == document.Id)
        .ToListAsync();

    DbContext.ValidationIssues.RemoveRange(oldIssues);

    document.Status = "Rejected";

    await DbContext.SaveChangesAsync();

    Navigation.NavigateTo("/dashboard");
}
}