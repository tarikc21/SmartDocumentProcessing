@page "/review/{Id:int}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using SmartDocumentProcessing.Data
@using SmartDocumentProcessing.Models
@using SmartDocumentProcessing.Services
@inject AppDbContext DbContext
@inject ValidationService ValidationService
@inject NavigationManager Navigation

<h1 class="page-title">Review Document</h1>
<p class="page-subtitle">Correct extracted data, re-run validation or reject the document.</p>

@if (document == null)
{
    <div style="background:#78350f; color:#fde68a; border:1px solid #f59e0b; border-radius:10px; padding:14px;">
        Document not found.
    </div>
}
else
{
    <div style="background:#111827; border:1px solid #1f2937; border-radius:16px; padding:24px;">
        <div class="mb-3">
            <label class="form-label" style="color:#cbd5e1;">Document Type</label>
            <input class="form-control bg-dark text-light border-secondary" @bind="document.DocumentType" />
        </div>

        <div class="mb-3">
            <label class="form-label" style="color:#cbd5e1;">Supplier Name</label>
            <input class="form-control bg-dark text-light border-secondary" @bind="document.SupplierName" />
        </div>

        <div class="mb-3">
            <label class="form-label" style="color:#cbd5e1;">Document Number</label>
            <input class="form-control bg-dark text-light border-secondary" @bind="document.DocumentNumber" />
        </div>

        <div class="mb-3">
            <label class="form-label" style="color:#cbd5e1;">Currency</label>
            <input class="form-control bg-dark text-light border-secondary" @bind="document.Currency" />
        </div>

        <div class="mb-3">
            <label class="form-label" style="color:#cbd5e1;">Subtotal</label>
            <input class="form-control bg-dark text-light border-secondary" type="number" step="0.01" @bind="document.Subtotal" />
        </div>

        <div class="mb-3">
            <label class="form-label" style="color:#cbd5e1;">Tax</label>
            <input class="form-control bg-dark text-light border-secondary" type="number" step="0.01" @bind="document.Tax" />
        </div>

        <div class="mb-3">
            <label class="form-label" style="color:#cbd5e1;">Total</label>
            <input class="form-control bg-dark text-light border-secondary" type="number" step="0.01" @bind="document.Total" />
        </div>

        <div class="mb-4">
            <label class="form-label" style="color:#cbd5e1;">Status</label>
            <select class="form-select bg-dark text-light border-secondary" @bind="document.Status">
                <option>Uploaded</option>
                <option>Needs Review</option>
                <option>Validated</option>
                <option>Rejected</option>
            </select>
        </div>

        <div style="display:flex; gap:10px;">
            <button style="background:#16a34a; color:white; border:none; border-radius:8px; padding:10px 16px; flex:1;"
                    @onclick="SaveChanges">
                Save Corrections
            </button>

            <button style="background:#dc2626; color:white; border:none; border-radius:8px; padding:10px 16px; flex:1;"
                    @onclick="RejectDocument">
                Reject
            </button>
        </div>
    </div>

    @if (issues.Any())
    {
        <div style="background:#450a0a; color:#fecaca; border:1px solid #dc2626; border-radius:12px; padding:18px; margin-top:18px;">
            <h5 style="color:white;">Validation Issues</h5>
            <ul style="margin-bottom:0;">
                @foreach (var issue in issues)
                {
                    <li>
                        <strong>@issue.Field:</strong> @issue.Message
                    </li>
                }
            </ul>
        </div>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Document? document;
    private List<ValidationIssue> issues = new();

    protected override async Task OnInitializedAsync()
    {
        document = await DbContext.Documents.FirstOrDefaultAsync(d => d.Id == Id);

        issues = await DbContext.ValidationIssues
            .Where(i => i.DocumentId == Id)
            .ToListAsync();
    }

    private async Task SaveChanges()
    {
        if (document == null)
            return;

        var oldIssues = await DbContext.ValidationIssues
            .Where(i => i.DocumentId == document.Id)
            .ToListAsync();

        DbContext.ValidationIssues.RemoveRange(oldIssues);

        var newIssues = await ValidationService.ValidateDocumentAsync(document);

        if (newIssues.Any())
        {
            document.Status = "Needs Review";
            DbContext.ValidationIssues.AddRange(newIssues);
        }
        else
        {
            document.Status = "Validated";
        }

        await DbContext.SaveChangesAsync();

        Navigation.NavigateTo("/dashboard");
    }

    private async Task RejectDocument()
    {
        if (document == null)
            return;

        var oldIssues = await DbContext.ValidationIssues
            .Where(i => i.DocumentId == document.Id)
            .ToListAsync();

        DbContext.ValidationIssues.RemoveRange(oldIssues);

        document.Status = "Rejected";

        await DbContext.SaveChangesAsync();

        Navigation.NavigateTo("/dashboard");
    }
}